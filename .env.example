# =====================================================================
# Tar Heel Web Co. — environment variables
# Copy to .env.local in each app that needs it. Never commit .env.local.
# =====================================================================

# --- Branding (hub + marketing only) ---
NEXT_PUBLIC_BRAND_NAME="Tar Heel Web Co."
NEXT_PUBLIC_BRAND_DOMAIN=tarheelweb.co

# --- Supabase (shared) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (hub only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STANDARD_MONTHLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_BUILD_STARTER=
STRIPE_PRICE_BUILD_STANDARD=
STRIPE_PRICE_BUILD_PREMIUM=

# --- Vercel API (for /admin/onboard provisioning) ---
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_SITE_TEMPLATE_REPO=tarheelweb/site-template

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="hello@tarheelweb.co"

# --- Cloudflare Turnstile (anti-spam on contact forms) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=

# --- PostHog (1M events/mo free forever) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_SERVER_KEY=

# =====================================================================
# Per-deployment site env (apps/site only; one set per client deploy)
# =====================================================================
SITE_ID=
REVALIDATION_SECRET=
PREVIEW_SECRET=
FORM_NOTIFICATION_EMAIL=
