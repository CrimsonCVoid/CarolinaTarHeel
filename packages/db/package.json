{
  "name": "@tarheel/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/database.types.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "migrate": "supabase db push",
    "gen-types": "supabase gen types typescript --linked > src/database.types.ts",
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tarheel/config": "workspace:*",
    "supabase": "^1.219.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
